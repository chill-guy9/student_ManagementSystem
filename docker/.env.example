# ============================================================
# 环境变量模板 - 学生管理系统
# 复制此文件为 .env 并修改为实际值
# ============================================================

# ==================== MySQL 配置 ====================
# ⚠️ 生产环境请务必修改默认密码！
MYSQL_ROOT_PASSWORD=<CHANGE_ME_TO_A_STRONG_PASSWORD>
MYSQL_DATABASE=sms_nexus
MYSQL_USER=student
MYSQL_PASSWORD=<CHANGE_ME_TO_A_STRONG_PASSWORD>
MYSQL_PORT=3306

# ==================== Redis 配置 ====================
# ⚠️ 生产环境请设置密码！
REDIS_PASSWORD=<CHANGE_ME_TO_A_STRONG_PASSWORD>
REDIS_PORT=6380

# ==================== 后端配置 ====================
BACKEND_PORT=8080
# ⚠️ 生产环境请务必替换JWT密钥！至少32个字符
JWT_SECRET=<CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY>

# ==================== 前端配置 ====================
FRONTEND_HTTP_PORT=80
FRONTEND_HTTPS_PORT=443

# ==================== 备份目录 ====================
BACKUP_DIR=/opt/student-management/backups
